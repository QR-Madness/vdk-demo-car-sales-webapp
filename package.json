{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:vite": "vite build",
        "test": "php artisan test",
        "services:up": "docker compose up -d && echo 'Waiting for MySQL...' && until docker exec laravel_mysql mysqladmin ping -h localhost -u root -proot --silent 2>/dev/null; do sleep 1; done && echo 'MySQL is ready!'",
        "services:up:raw": "docker compose up -d",
        "services:down": "docker compose down",
        "db:migrate": "php artisan migrate",
        "db:seed": "php artisan db:seed",
        "db:reset": "php artisan migrate:fresh --seed",
        "dev": "php artisan build && php artisan serve --port 12936",
        "dev:hmr": "concurrently \"php artisan serve --port 12936\" \"vite\" --names=laravel,vite --prefix-colors=blue,green"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@vitejs/plugin-vue": "^6.0.5",
        "axios": ">=1.11.0 <=1.14.0",
        "concurrently": "^9.2.1",
        "laravel-vite-plugin": "^3.0.1",
        "tailwindcss": "^4.2.2",
        "vite": "^8.0.8"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.0.3",
        "vue": "^3.5.32"
    }
}
